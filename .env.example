# Copier en .env et remplir les valeurs. Voir CLAUDE.md pour le detail.

# Fournisseur d'IA : mistral (defaut), claude ou gemini
LLM_PROVIDER=mistral

# Mistral
MISTRAL_KEY=
MISTRAL_MODEL=mistral-small-latest

# Claude (Anthropic)
ANTHROPIC_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# Gemini
GEMINI_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Admin web
ADMIN_PASSWORD=minitelgpt
FLASK_SECRET=change-me

# URL publique de l'admin, affichee sur le Minitel via la touche GUIDE
ADMIN_PUBLIC_URL=

# Jeton requis en ?token=... pour se connecter a /ws, /ws-echo, /ws-gemini.
# Vide = pas de verification (n'importe qui connaissant l'URL peut discuter
# et consommer ta cle API). Mets une valeur aleatoire en prod.
WS_TOKEN=
