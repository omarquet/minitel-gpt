[Unit]
Description=Minitel ChatGPT (Claude)
After=network-online.target wifi-manager.service
Wants=network-online.target

[Service]
Type=simple
User=minitel
WorkingDirectory=/home/minitel/minitel-gpt
EnvironmentFile=/home/minitel/minitel-gpt/.env
ExecStart=/usr/bin/python3 /home/minitel/minitel-gpt/services/minitel_chatgpt.py
Restart=on-failure
RestartSec=10
StandardOutput=append:/home/minitel/minitel-gpt/logs/chatgpt.log
StandardError=append:/home/minitel/minitel-gpt/logs/chatgpt.log

[Install]
WantedBy=multi-user.target
